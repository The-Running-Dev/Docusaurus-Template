{
  "compilerOptions": {
    // Override settings specific to pre-build script
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./build",
    "rootDir": "..", // Changed from "." to ".." to allow imports from ../src/
    "sourceMap": true,
    "declaration": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // Node.js specific settings
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    // Remove DOM types for Node.js script
    //"lib": ["ES2020"],
    //"types": ["node"],

    // Path mapping for imports
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./config/*"],
      "@data/*": ["./data/*"],
      "@scripts/*": ["./scripts/*"]
    }
  },
  "include": ["pre-build.ts", "../data/**/*", "../config/**/*", "../src/**/*"],
  "exclude": [
    "node_modules",
    "../build",
    "../artifacts",
    "../.docusaurus",
    "build"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
